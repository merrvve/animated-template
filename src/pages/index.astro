<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Animated Astro</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0d1117;
      color: #fff;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      overflow-x: hidden;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 2.5rem;
      background: rgba(13, 17, 23, 0.65);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .nav-brand {
      font-size: 1.15rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 2.25rem;
    }

    .nav-links a {
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: #fff; }

    .nav-cta {
      padding: 0.5rem 1.3rem;
      background: #fff;
      color: #000;
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      border-radius: 4px;
      transition: opacity 0.2s;
    }

    .nav-cta:hover { opacity: 0.82; }

    /* ── STAGE ── */
    .stage {
      height: 600vh;
      position: relative;
    }

    .layers {
      position: sticky;
      top: 0;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }

    .layer {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
    }

    /* ── PROGRESS BAR ── */
    .progress-bar {
      position: absolute;
      right: 2rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .segment {
      width: 2px;
      height: 52px;
      background: rgba(255,255,255,0.15);
      border-radius: 2px;
      overflow: hidden;
    }

    .segment .fill {
      width: 100%;
      height: 0%;
      background: #fff;
      border-radius: 2px;
    }

    /* ── TEXTS ── */
    .texts {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      pointer-events: none;
      z-index: 20;
    }

    .txt {
      position: absolute;
      bottom: 3.5rem;
      left: 4rem;
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.5s ease, transform 0.5s ease;
      max-width: 620px;
    }

    .txt.active {
      opacity: 1;
      transform: translateY(0);
    }

    .txt .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 0.9rem;
    }

    .txt h1 {
      font-size: clamp(3.5rem, 9vw, 8rem);
      font-weight: 900;
      line-height: 0.88;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }

    .txt p {
      font-size: 0.875rem;
      line-height: 1.7;
      color: rgba(255,255,255,0.55);
      max-width: 380px;
    }

    /* ── SECTIONS BELOW STAGE ── */
    .sec {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 4rem;
    }

    .sec-inner {
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
    }

    .sec-tag {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 1rem;
    }

    .sec-title {
      font-size: clamp(2rem, 5vw, 3.75rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }

    .sec-text {
      color: rgba(255,255,255,0.55);
      line-height: 1.75;
      max-width: 560px;
      font-size: 0.95rem;
      margin-bottom: 3rem;
    }

    /* Features */
    .sec-features { background: #0a2818; }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
      margin-top: 3rem;
    }

    .feature-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 2rem 1.75rem;
    }

    .feature-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      margin-bottom: 1.25rem;
    }

    .feature-card h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.6rem;
    }

    .feature-card p {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.65;
    }

    /* Pricing */
    .sec-pricing { background: #1a0a38; }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }

    .pricing-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 2.5rem;
    }

    .pricing-card.featured {
      background: rgba(255,255,255,0.09);
      border-color: rgba(255,255,255,0.22);
    }

    .pricing-card .plan-name {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      margin-bottom: 0.75rem;
    }

    .pricing-price {
      font-size: 3.25rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.25rem;
    }

    .pricing-price sub {
      font-size: 1rem;
      font-weight: 400;
      color: rgba(255,255,255,0.45);
    }

    .pricing-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.45);
      margin-bottom: 2rem;
    }

    .pricing-features {
      list-style: none;
      margin-bottom: 2rem;
    }

    .pricing-features li {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .btn {
      display: inline-block;
      padding: 0.75rem 1.6rem;
      border-radius: 6px;
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      cursor: pointer;
      border: none;
      letter-spacing: 0.04em;
      transition: opacity 0.2s;
    }

    .btn:hover { opacity: 0.8; }
    .btn-primary { background: #fff; color: #000; }
    .btn-outline { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.25); }

    /* CTA */
    .sec-cta {
      background: #380a0a;
      text-align: center;
      flex-direction: column;
      justify-content: center;
    }

    .sec-cta .sec-inner { text-align: center; }
    .sec-cta .sec-text { margin: 0 auto 3rem; }

    .cta-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ── TESTIMONIALS ── */
    .sec-testimonials {
      background: #0d1117;
      padding: 8rem 4rem 10rem;
      overflow: visible;
    }

    .tmg-wrap {
      overflow: hidden;
      margin: 3rem -1rem 0;
      padding: 2rem 1rem 4rem;
    }

    .tmg-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
      position: relative;
    }

    .tmg-item {
      background: var(--card-bg, #1e3a5f);
      border-radius: 14px;
      padding: 1.5rem 1.25rem;
      cursor: pointer;
      position: relative;
      will-change: transform;
      user-select: none;
      aspect-ratio: 3 / 4;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      transition: box-shadow 0.25s;
      transform-origin: center center;
    }

    .tmg-item:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }

    .tmg-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-bottom: 0.25rem;
    }

    .tmg-name {
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .tmg-role {
      font-size: 0.68rem;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .tmg-quote {
      font-size: 0.78rem;
      line-height: 1.65;
      color: rgba(255, 255, 255, 0.65);
      display: -webkit-box;
      -webkit-line-clamp: 5;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-top: auto;
    }

    .tmg-hint {
      text-align: center;
      margin-top: 3rem;
      font-size: 0.68rem;
      color: rgba(255, 255, 255, 0.2);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    @media (max-width: 1000px) {
      .tmg-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 680px) {
      .tmg-grid { grid-template-columns: repeat(2, 1fr); }
      .sec-testimonials { padding: 6rem 2rem 8rem; }
    }

    /* Footer */
    .footer {
      background: #000;
      padding: 5rem 4rem 3rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto 4rem;
    }

    .footer-brand {
      font-size: 1.1rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .footer-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.35);
      line-height: 1.7;
      max-width: 280px;
    }

    .footer-col h4 {
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 1.25rem;
    }

    .footer-col ul { list-style: none; }

    .footer-col li { margin-bottom: 0.65rem; }

    .footer-col a {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-col a:hover { color: #fff; }

    .footer-bottom {
      max-width: 1200px;
      margin: 0 auto;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .footer-bottom p {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.25);
    }

    @media (max-width: 900px) {
      .nav-links { display: none; }
      .txt { left: 2rem; }
      .sec { padding: 6rem 2rem; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 540px) {
      .footer-grid { grid-template-columns: 1fr; }
      .footer { padding: 4rem 2rem 2rem; }
    }
  </style>
</head>
