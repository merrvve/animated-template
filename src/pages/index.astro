---
import '../styles/global.css';
import StageSection from '../components/stage-section.astro';
import HowToUseSection from '../components/how-to-use-section.astro';
import CTASection from '../components/cta-section.astro';

import Base from '../layouts/Base.astro';
---
<Base title="home" description="desc">

<StageSection />
<HowToUseSection />
<CTASection />


<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // ── CONFIG ──────────────────────────────────────
  const BLIND_COUNT = 24;
  const VB_HEIGHT = 100;
  const MASKED_LAYERS = [1, 2, 3, 4];
  const TOTAL_SECTIONS = 5;
  const TEXT_THRESHOLDS = [0, 0.125, 0.375, 0.625, 0.875];

  let vbWidth = 0;
  let masterTl: gsap.core.Timeline;
  const blindsData: Record<number, Array<{ top: SVGRectElement; bottom: SVGRectElement; y: number; h: number }>> = {};
  let lenis: Lenis | undefined;
  let lenisRafCb: ((time: number) => void) | undefined;
  let resizeTimer: ReturnType<typeof setTimeout>;

  function calcVbWidth() {
    return (window.innerWidth / window.innerHeight) * VB_HEIGHT;
  }

  // ── SVG HELPERS ─────────────────────────────────
  function setSvgViewBox(idx: number) {
    const svg = document.getElementById(`layer${idx}`) as SVGSVGElement | null;
    svg?.setAttribute('viewBox', `0 0 ${vbWidth} ${VB_HEIGHT}`);
  }

  function updateSvgWidths(idx: number) {
    const svg = document.getElementById(`layer${idx}`);
    svg?.querySelectorAll('rect').forEach(r => r.setAttribute('width', String(vbWidth + 1)));
  }

  function createBlinds(layerIdx: number) {
    const gEl = document.getElementById(`blinds${layerIdx}`)!;
    while (gEl.firstChild) gEl.removeChild(gEl.firstChild);

    const h = VB_HEIGHT / BLIND_COUNT;
    const blinds: typeof blindsData[number] = [];
    const ns = 'http://www.w3.org/2000/svg';

    for (let i = 0; i < BLIND_COUNT; i++) {
      const centerY = VB_HEIGHT - (i * h + h / 2);

      const makeRect = () => {
        const r = document.createElementNS(ns, 'rect') as SVGRectElement;
        r.setAttribute('x', '0');
        r.setAttribute('y', String(centerY));
        r.setAttribute('width', String(vbWidth + 1));
        r.setAttribute('height', '0');
        r.setAttribute('fill', 'white');
        r.setAttribute('shape-rendering', 'crispEdges');
        gEl.appendChild(r);
        return r;
      };

      blinds.push({ top: makeRect(), bottom: makeRect(), y: centerY, h });
    }

    blindsData[layerIdx] = blinds;
    return blinds;
  }

  function buildOpenTimeline(blinds: typeof blindsData[number]) {
    const rects = blinds.flatMap(b => [b.top, b.bottom]);

    return gsap.timeline().to(rects, {
      attr: {
        y: (i: number) => {
          const b = blinds[Math.floor(i / 2)];
          return i % 2 === 0 ? b.y - b.h : b.y;
        },
        height: (i: number) => {
          const b = blinds[Math.floor(i / 2)];
          return b.h + 0.01;
        },
      },
      ease: 'none',
      stagger: { each: 0.02, from: 'start' },
      duration: 1,
    });
  }

  // ── INIT ─────────────────────────────────────────
  function init() {
    vbWidth = calcVbWidth();

    for (let i = 0; i <= 4; i++) {
      setSvgViewBox(i);
      updateSvgWidths(i);
    }

    masterTl = gsap.timeline({ paused: true });
    MASKED_LAYERS.forEach(idx => {
      masterTl.add(buildOpenTimeline(createBlinds(idx)), '>');
    });

    ScrollTrigger.create({
      trigger: '.stage',
      start: 'top top',
      end: '+=' + window.innerHeight * 5,
      pin: true,
      scrub: 2.2,
      animation: masterTl,
      onUpdate(self) {
        updateProgressBar(self.progress);
        updateActiveText(self.progress);
      },
    });
  }

  // ── UI UPDATES ───────────────────────────────────
  function updateProgressBar(progress: number) {
    const fills = document.querySelectorAll<HTMLElement>('.segment .fill');
    const per = 1 / TOTAL_SECTIONS;
    fills.forEach((fill, i) => {
      const start = i * per;
      const end = (i + 1) * per;
      if (progress >= end) fill.style.height = '100%';
      else if (progress >= start) fill.style.height = `${((progress - start) / per) * 100}%`;
      else fill.style.height = '0%';
    });
  }

  function updateActiveText(progress: number) {
    let active = 0;
    for (let i = TEXT_THRESHOLDS.length - 1; i >= 0; i--) {
      if (progress >= TEXT_THRESHOLDS[i]) { active = i; break; }
    }
    document.querySelectorAll('.txt').forEach((el, i) => {
      el.classList.toggle('active', i === active);
    });
    document.querySelector('.pricing-stage-cards')
      ?.classList.toggle('active', active === 3);
  }

  // ── MAKE WAY GRID ────────────────────────────────
  function initMakeWayGrid() {
    const grid = document.querySelector<HTMLElement>('.tmg-grid');
    if (!grid) return;

    const items = [...grid.querySelectorAll<HTMLElement>('.tmg-item')];
    let activeItem: HTMLElement | null = null;

    const cfg = {
      duration:    parseFloat(grid.dataset.duration    ?? '0.85'),
      ease:                   grid.dataset.ease        ?? 'elastic.out(0.4,0.3)',
      scale:       parseFloat(grid.dataset.scale       ?? '2.15'),
      maxRotation: parseFloat(grid.dataset.maxRotation ?? '22'),
      spread:      parseFloat(grid.dataset.spread      ?? '170'),
      maxDistance: parseFloat(grid.dataset.maxDistance ?? '780'),
    };

    const origins = new Map<HTMLElement, { x: number; y: number }>();
    items.forEach(item => {
      origins.set(item, {
        x: item.offsetLeft + item.offsetWidth  / 2,
        y: item.offsetTop  + item.offsetHeight / 2,
      });
    });

    function resetAll(skip: HTMLElement | null = null) {
      items.forEach(item => {
        if (item === skip) return;
        gsap.to(item, {
          x: 0, y: 0, rotation: 0, scale: 1,
          zIndex: 1,
          duration: cfg.duration,
          ease: cfg.ease,
        });
      });
    }

    function expand(item: HTMLElement) {
      activeItem = item;
      const cc = origins.get(item)!;

      gsap.to(item, {
        scale: cfg.scale,
        zIndex: 100,
        duration: cfg.duration,
        ease: cfg.ease,
      });

      items.forEach(other => {
        if (other === item) return;

        const oc = origins.get(other)!;
        const dx = oc.x - cc.x;
        const dy = oc.y - cc.y;
        const dist = Math.hypot(dx, dy);

        if (dist === 0 || dist > cfg.maxDistance) return;

        const falloff = 1 - dist / cfg.maxDistance;
        const moveX   = (dx / dist) * cfg.spread * falloff;
        const moveY   = (dy / dist) * cfg.spread * falloff;
        const rot     = (Math.random() * 2 - 1) * cfg.maxRotation * falloff;

        gsap.to(other, {
          x: moveX, y: moveY, rotation: rot,
          duration: cfg.duration,
          ease: cfg.ease,
        });
      });
    }

    grid.addEventListener('click', (e: MouseEvent) => {
      const item = (e.target as Element).closest<HTMLElement>('.tmg-item');

      if (!item) {
        resetAll();
        activeItem = null;
        return;
      }

      if (item === activeItem) {
        resetAll();
        activeItem = null;
        return;
      }

      resetAll(item);
      expand(item);
    });
  }

  // ── SETUP (runs on every page load / view transition) ────
  function setup() {
    // Clean up previous instances before re-initialising
    ScrollTrigger.getAll().forEach(t => t.kill());
    if (lenisRafCb) gsap.ticker.remove(lenisRafCb);
    lenis?.destroy();

    lenis = new Lenis();
    lenis.on('scroll', ScrollTrigger.update);
    lenisRafCb = (time: number) => lenis!.raf(time * 1000);
    gsap.ticker.add(lenisRafCb);
    gsap.ticker.lagSmoothing(0);

    init();
    initMakeWayGrid();
  }

  // ── RESIZE ───────────────────────────────────────
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ScrollTrigger.getAll().forEach(t => t.kill());
      init();
    }, 220);
  });

  // astro:page-load fires after every view-transition navigation
  document.addEventListener('astro:page-load', setup);
  // Also call immediately: ClientRouter fires astro:page-load during its own
  // module init, which runs before this deferred script registers the listener.
  setup();
</script>



</Base>
