  { bg: '#2d1a4f', av: '#7c3aed', name: 'Amet Consectetur',  role: 'CTO at Adipiscing',         quote: 'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo.' },
  { bg: '#0a3d2a', av: '#059669', name: 'Sed Do Eiusmod',    role: 'Designer at Tempor',        quote: 'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.' },
